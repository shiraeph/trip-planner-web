# API origin (scheme + host + port, no trailing slash). Required when the SPA is hosted on a
# different domain than the Spring API. Example: https://api.myserver.com
# Leave unset only if requests are proxied to the backend on the SAME origin (/api → backend).
#
# Must be defined at BUILD time:
#   VITE_API_URL=https://api.example.com npm run build

VITE_API_URL=http://localhost:8080
